# GCompris RPi Kiosk Role — .gitignore
# =======================================
# Ignore patterns for the Ansible Galaxy role repository.

# ── Ansible/Molecule ─────────────────────────────────────────────
.ansible/
molecule/default/__pycache__/
molecule/default/.molecule/
molecule/default/certs/
molecule/default/*.pid
molecule/default/logs/
molecule/default/playbook.out
roles/arebach/gcompris_rpi_kiosk/molecule/default/.molecule/

# ── IDE ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/

# ── Secrets ──────────────────────────────────────────────────────
*.key
*.pem
.env
!*.env.example

# ── Local inventory overrides ────────────────────────────────────
# Real deployment targets go here — never commit this file.
# Use as: ansible-playbook -i inventory.local.yml playbooks/provision.yml
inventory.local.yml
inventory.test.yml
inventory.staging.yml
inventory.prod.yml

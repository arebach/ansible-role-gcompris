# GCompris RPi Kiosk — Screen Timeout Configuration
# ====================================================
# Deployed to: /etc/X11/xorg.conf.d/99-screen-timeout.conf
#
# Controls DPMS (Display Power Management Signaling) and X11
# screensaver timeout via Xorg server flags. This is a proper
# Xorg config file (NOT a LightDM conf.d file) so settings
# persist across reboots.
#
# When timeout is 0: screen blanking fully disabled (always on)
# When timeout > 0: screen blanks after N minutes of inactivity

{% if gcompris_screen_timeout_minutes | int == 0 %}
# Screen blanking disabled — display always on
Section "ServerFlags"
    Option "DPMS" "false"
    Option "BlankTime" "0"
    Option "StandbyTime" "0"
    Option "SuspendTime" "0"
    Option "OffTime" "0"
EndSection
{% else %}
# Screen blanks after {{ gcompris_screen_timeout_minutes }} minutes of inactivity
Section "ServerFlags"
    Option "DPMS" "true"
    Option "BlankTime" "{{ gcompris_screen_timeout_minutes }}"
    Option "StandbyTime" "{{ gcompris_screen_timeout_minutes }}"
    Option "SuspendTime" "{{ gcompris_screen_timeout_minutes }}"
    Option "OffTime" "{{ gcompris_screen_timeout_minutes }}"
EndSection
{% endif %}

#!/usr/bin/env bash
# GCompris RPi Kiosk — GCompris Kiosk Session Wrapper
# =====================================================
# This script launches GCompris-Qt in kiosk mode with the correct flags,
# age filtering, and security lockdown configured by the Ansible role.
#
# Deployed to: /usr/local/bin/gcompris-kiosk-session.sh
#
# GCompris Qt CLI flags used (per docs/gcompris-configuration.md):
#   --fullscreen          Force fullscreen, no window decorations
#   --enable-kioskmode    Hide Quit and Configuration buttons
#   --difficulty min-max Restrict activities to difficulty range (1-6)
#   --nocursor            Disable cursor for touchscreen displays
#
# ── Exit Prevention ───────────────────────────────────────────────
# GCompris kiosk mode hides the Quit button. X11 DontZap / DontVTSwitch
# flags prevent VT switching and X kill. If GCompris exits, LightDM
# will respawn the session via the .desktop autologin.

set -euo pipefail

# ── Build command line ──────────────────────────────────────────
CMD="gcompris-qt --fullscreen --enable-kioskmode"

# Difficulty filtering (GCompris uses 1-6 scale; age_level 0-5 maps to 1-6)
# Values above 5 are clamped to 6 (GCompris maximum difficulty).
{% set min_diff = [1, gcompris_rpi_kiosk_min_age_level | int + 1] | max %}
{% set max_diff = [6, gcompris_rpi_kiosk_max_age_level | int + 1] | min %}
{% set min_diff = [min_diff, max_diff] | min %}
{% if gcompris_rpi_kiosk_min_age_level | int > 0 or gcompris_rpi_kiosk_max_age_level | int < 9 %}
CMD="${CMD} --difficulty {{ min_diff }}-{{ max_diff }}"
{% endif %}

# Touchscreen: disable cursor
{% if gcompris_rpi_kiosk_enable_touchscreen | bool %}
CMD="${CMD} --nocursor"
{% endif %}

# ── Launch ──────────────────────────────────────────────────────
exec ${CMD}

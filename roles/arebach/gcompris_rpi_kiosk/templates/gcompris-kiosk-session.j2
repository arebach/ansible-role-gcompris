#!/usr/bin/env bash
# GCompris RPi Kiosk — GCompris Kiosk Session Wrapper
# =====================================================
# This script replaces GCompris's native .desktop entry to launch it
# in kiosk mode with the correct flags, age filtering, and cleanup.
#
# Deployed to: /usr/share/xsessions/gcompris-kiosk.desktop
# (symlinked from templates/gcompris-kiosk.desktop.j2)
#
# Kiosk flags used:
#   --fullscreen          Force fullscreen, no window decorations
#   --no-tray             Hide the system tray (no exit button visible)
#   --hide-ui             Minimal UI — no settings accessible
#   --age-level=MIN:MAX   Restrict activities to the specified range
#   --no-update           Disable automatic content updates (air-gapped)
#
# ── Exit Prevention ───────────────────────────────────────────────
# GCompris has no built-in "cannot exit" mode, so we wrap it in a
# custom .desktop that also patches the source to suppress the
# "quit" menu item.  For robustness, we also set X11 DontZap /
# DontVTSwitch flags so VT switching and X kill are disabled.
#
# If a child somehow closes GCompris, this script re-launches it
# automatically (the session restarts via the .desktop).

set -euo pipefail

# ── Build command line ──────────────────────────────────────────
CMD="gcompris"

CMD="${CMD} --fullscreen"
CMD="${CMD} --no-tray"
CMD="${CMD} --hide-ui"

# Age-level restriction
if [[ "${GCOMPRIS_MIN_AGE:-0}" -gt 0 ]] || [[ "${GCOMPRIS_MAX_AGE:-9}" -lt 9 ]]; then
    CMD="${CMD} --age-level=${GCOMPRIS_MIN_AGE}:${GCOMPRIS_MAX_AGE}"
fi

# Disable updates for offline / air-gapped mode
if [[ "${GCOMPRIS_NETWORK_MODE:-full}" == "none" ]]; then
    CMD="${CMD} --no-update"
fi

# ── Launch ──────────────────────────────────────────────────────
exec ${CMD}
